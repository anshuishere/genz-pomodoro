{
  "name": "truefocus",
  "version": "1.0.0",
  "description": "A productivity-focused Chrome extension for managing focus time and tasks",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "watch": "tsc && vite build --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chrome-extension",
    "productivity",
    "focus",
    "pomodoro",
    "manifest-v3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {}
}
